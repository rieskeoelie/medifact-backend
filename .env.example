# BCK Research Intelligence API — Environment Variables

# REQUIRED: Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# OPTIONAL: Model to use (default: claude-haiku-4-5-20251001 — fast & cheap)
# Use claude-sonnet-4-6 for more precise consensus analysis (A3, A4, A5, A7)
BCK_MODEL=claude-haiku-4-5-20251001

# OPTIONAL: Port (default: 8000)
PORT=8000
